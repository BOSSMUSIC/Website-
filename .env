# Rename this file to ".env" and fill in your real Gmail credentials.
# Do NOT commit your real .env file to GitHub.

# The Gmail account that will SEND the emails (can be any Gmail account)
EMAIL_USER=your_gmail_address@gmail.com

# A 16-character Gmail "App Password" (NOT your normal Gmail password)
# How to get one: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_16_character_app_password

# Port the server runs on (optional)
PORT=5000
